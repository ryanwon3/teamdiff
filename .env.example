# Riot developer portal: https://developer.riotgames.com/
RIOT_API_KEY=your_api_key_here

# Regional route for Match-V5 (NA: americas)
RIOT_REGIONAL_ROUTE=americas

# Platform/shard for League-V4 + Summoner-V4 (NA ranked: na1)
# RIOT_PLATFORM_ROUTE=na1

# Comma-separated PUUIDs whose match history is sampled (no spaces, or trim handled on load).
# Must be on the SAME line as the key — do not put a line break between = and the id.
MATCHUP_SEED_PUUIDS=your_puuid_here

# Optional: if the line above is empty, you can put one PUUID per line in puuids.txt
# at the project root (copy from puuids.txt.example). That file is gitignored.

# Max match detail requests per /api/matchup call (keeps prototype under dev key limits)
MATCHUP_MAX_MATCHES=30

# Ranked Solo / Draft Pick etc. Use 420 for ranked solo (recommended with ladder seeds).
# MATCHUP_QUEUE_ID=420

# Ladder seeds: full Challenger + Grandmaster + paginated Master (requires RIOT_PLATFORM_ROUTE).
# MATCHUP_LADDER_SEEDS=1
# MATCHUP_LADDER_TIERS=CHALLENGER,GRANDMASTER,MASTER
# 0 = use every summoner returned for Challenger/Grandmaster (no cap). Set e.g. 50 to throttle.
# MATCHUP_LADDER_MAX_PER_TIER=0
# Master only: how many API pages (200 entries each) to pull per ladder refresh (rate limits).
# MATCHUP_LADDER_MASTER_MAX_PAGES=3
# File storing next Master league page index (rotates through the full Master list over time).
# MATCHUP_LADDER_MASTER_CURSOR_PATH=data/ladder_master_page.cursor
# MATCHUP_LEAGUE_QUEUE_TYPE=RANKED_SOLO_5x5

# Optional: only ingest matches whose match_id starts with this prefix (NA shard: NA1_)
# MATCHUP_MATCH_ID_PREFIX=NA1_

# Tier 2: SQLite store (run: python collect_matches.py in another terminal)
# MATCHUP_DB_PATH=data/matchups.db
# If 0/false/no: /api/matchup uses only the DB (must exist). Default: live Riot fallback when DB is empty.
# MATCHUP_LIVE_FALLBACK=1
# COLLECTOR_SLEEP_SECONDS=60
# COLLECTOR_MATCHLIST_COUNT=20
# How often collect_matches.py refetches ladder PUUIDs (new promos/demotions).
# COLLECTOR_SEED_REFRESH_SECONDS=3600
